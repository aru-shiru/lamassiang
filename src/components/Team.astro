---
import { useTranslations } from "../i18n/translations";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const people = [
  { photo: "/images/team/person-2.jpg", name: "Siti Rahmadani, S.H., LL.M." },
  { photo: "/images/team/person-3.jpg", name: "Bharata Wijaya, S.H., M.H." },
  { photo: "/images/team/person-4.jpg", name: "Maria Tandiari, S.H." },
  { photo: "/images/team/person-5.jpg", name: "Daniel Pasaribu, S.H., M.Kn." },
  { photo: "/images/team/person-6.jpg", name: "Nurul Fadhilah, S.H." },
  { photo: "/images/team/person-7.jpg", name: "Reza Mahendra, S.H., LL.M." },
];

const members = people.map((p, i) => ({ ...p, role: t.team.roles[i] }));
---

<section class="section team" id="team">
  <div class="container">
    <div class="team-head reveal">
      <p class="eyebrow">{t.team.eyebrow}</p>
      <h2 class="section-title">{t.team.title}</h2>
      <p class="section-lead">{t.team.lead}</p>
    </div>

    <div class="team-grid">
      {
        members.map((m, i) => (
          <article class="team-card reveal" style={`transition-delay: ${(i % 3) * 0.08}s`}>
            <div class="team-photo">
              <img src={m.photo} alt={`${t.team.photoAltPrefix} ${m.name}`} loading="lazy" />
            </div>
            <h3>{m.name}</h3>
            <p>{m.role}</p>
          </article>
        ))
      }
    </div>

    <p class="team-note reveal">{t.team.note}</p>
  </div>
</section>

<style>
  .team {
    background: var(--paper);
  }

  .team-head {
    text-align: center;
    margin-bottom: 56px;
  }

  .team-head .eyebrow {
    justify-content: center;
  }

  .team-head .eyebrow::after {
    content: "";
    width: 36px;
    height: 1px;
    background: var(--gold);
  }

  .team-head .section-lead {
    margin-inline: auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px 28px;
  }

  .team-card {
    text-align: center;
  }

  .team-photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--cream);
  }

  .team-photo img {
    width: 100%;
    aspect-ratio: 1 / 1.1;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .team-card:hover .team-photo img {
    transform: scale(1.04);
  }

  .team-card h3 {
    font-size: 1.12rem;
    margin-bottom: 4px;
  }

  .team-card p {
    color: var(--gold);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .team-note {
    margin-top: 48px;
    text-align: center;
    font-size: 0.85rem;
    color: var(--ink-soft);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .team-grid { grid-template-columns: 1fr; max-width: 340px; margin-inline: auto; }
  }
</style>

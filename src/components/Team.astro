---
import { useTranslations } from "../i18n/translations";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const people = [
  { photo: "/images/team/walid.png", name: "Muhammad Walid T, S.H." },
  { photo: "/images/team/hidayatullah.png", name: "Hidayatullah, S.H." },
  { photo: "/images/team/afrisya.png", name: "Muhammad Afrisya Hasyim, S.H." },
  { photo: "/images/team/tanrasula.png", name: "A. Tanrasula, S.H." },
  { photo: "/images/team/pangeran.png", name: "Pangeran Alfayed Ruslan, S.H." },
  { photo: "/images/team/azzahra.png", name: "Az Zahra Nabillah Kamil, S.H." },
];

const members = people.map((p, i) => ({
  ...p,
  role: t.team.roles[i],
  bio: t.team.bios[i],
}));
---

<section class="section team" id="team">
  <div class="container">
    <div class="team-head reveal">
      <p class="eyebrow">{t.team.eyebrow}</p>
      <h2 class="section-title">{t.team.title}</h2>
      <p class="section-lead">{t.team.lead}</p>
    </div>

    <div class="team-grid">
      {
        members.map((m, i) => (
          <article class="team-card reveal" style={`transition-delay: ${(i % 3) * 0.08}s`}>
            <div class="team-photo">
              <img src={m.photo} alt={`${t.team.photoAltPrefix} ${m.name}`} loading="lazy" />
            </div>
            <h3>{m.name}</h3>
            <p class="team-role">{m.role}</p>
            <p class="team-bio">{m.bio}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .team {
    background: var(--paper);
  }

  .team-head {
    text-align: center;
    margin-bottom: 56px;
  }

  .team-head .eyebrow {
    justify-content: center;
  }

  .team-head .eyebrow::after {
    content: "";
    width: 36px;
    height: 1px;
    background: var(--gold);
  }

  .team-head .section-lead {
    margin-inline: auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 28px;
  }

  /* centre the lone last card when 7 members leave one on its own row */
  .team-card:last-child:nth-child(3n + 1) {
    grid-column: 2;
  }

  .team-card {
    text-align: center;
  }

  .team-photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--cream);
  }

  .team-photo img {
    width: 100%;
    aspect-ratio: 1 / 1.05;
    object-fit: cover;
    object-position: center;
    transition: transform 0.4s ease;
  }

  .team-card:hover .team-photo img {
    transform: scale(1.04);
  }

  .team-card h3 {
    font-size: 1.12rem;
    margin-bottom: 4px;
  }

  .team-role {
    color: var(--gold);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .team-bio {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .team-card:last-child:nth-child(3n + 1) { grid-column: auto; }
  }

  @media (max-width: 560px) {
    .team-grid {
      grid-template-columns: 1fr;
      max-width: 340px;
      margin-inline: auto;
    }
  }
</style>

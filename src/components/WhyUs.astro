---
import { useTranslations } from "../i18n/translations";

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<section class="section why">
  <div class="container why-grid">
    <div class="why-content reveal">
      <p class="eyebrow">{t.why.eyebrow}</p>
      <h2 class="section-title">{t.why.titleLine1}<br />{t.why.titleLine2}</h2>
      <p class="section-lead">{t.why.lead}</p>
      <ul class="why-list">
        {
          t.why.values.map((v) => (
            <li>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
            </li>
          ))
        }
      </ul>
    </div>

    <figure class="why-photo reveal">
      <img src="/images/justice.jpg" alt={t.why.photoAlt} loading="lazy" />
      <figcaption>
        <span class="quote-mark">”</span>
        <p>{t.why.quote}</p>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .why {
    background: var(--navy);
    color: #fff;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: center;
  }

  .why .section-title {
    color: #fff;
  }

  .why .section-lead {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 40px;
  }

  .why-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 36px;
  }

  .why-list h3 {
    color: var(--gold-soft);
    font-size: 1.08rem;
    margin-bottom: 6px;
  }

  .why-list p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
  }

  .why-photo {
    position: relative;
  }

  .why-photo img {
    border-radius: var(--radius);
    aspect-ratio: 4 / 5;
    object-fit: cover;
    width: 100%;
  }

  .why-photo figcaption {
    position: absolute;
    left: -36px;
    bottom: 32px;
    max-width: 290px;
    background: var(--gold);
    color: #fff;
    border-radius: 12px;
    padding: 22px 24px 20px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 0.4;
    display: block;
    margin-bottom: 10px;
  }

  .why-photo figcaption p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }

    .why-photo {
      max-width: 460px;
    }

    .why-photo figcaption {
      left: 16px;
    }
  }

  @media (max-width: 560px) {
    .why-list { grid-template-columns: 1fr; }
  }
</style>
